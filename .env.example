# Persona POS Configuration
# Copy this file to .env.local and fill in your values

# ===== Database =====
# Adapter: indexeddb | sqlite | postgres
VITE_DB_ADAPTER=indexeddb

# For PostgreSQL (when adapter=postgres)
# VITE_DB_HOST=localhost
# VITE_DB_PORT=5432
# VITE_DB_NAME=persona_pos
# VITE_DB_USER=postgres
# VITE_DB_PASSWORD=your_password

# For SQLite (when adapter=sqlite)
# VITE_DB_FILENAME=./persona-pos.db

# ===== Authentication =====
# Adapter: local | oidc | google
VITE_AUTH_ADAPTER=local
VITE_AUTH_SESSION_DURATION=86400000

# For OIDC (when adapter=oidc)
# VITE_AUTH_ISSUER=https://your-issuer.com
# VITE_AUTH_CLIENT_ID=your_client_id
# VITE_AUTH_CLIENT_SECRET=your_client_secret
# VITE_AUTH_REDIRECT_URI=http://localhost:5173/callback

# For Google OAuth (when adapter=google)
# VITE_AUTH_GOOGLE_CLIENT_ID=your_google_client_id
# VITE_AUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===== Email =====
# Adapter: console | smtp | resend
VITE_EMAIL_ADAPTER=console
VITE_EMAIL_FROM=noreply@example.com

# For SMTP (when adapter=smtp)
# VITE_EMAIL_HOST=smtp.gmail.com
# VITE_EMAIL_PORT=587
# VITE_EMAIL_SECURE=false
# VITE_EMAIL_USER=your_email@gmail.com
# VITE_EMAIL_PASSWORD=your_password

# For Resend (when adapter=resend)
# VITE_EMAIL_RESEND_API_KEY=re_your_api_key

# ===== SMS =====
# Adapter: console | twilio
VITE_SMS_ADAPTER=console
VITE_SMS_FROM=+1234567890

# For Twilio (when adapter=twilio)
# VITE_SMS_TWILIO_ACCOUNT_SID=your_account_sid
# VITE_SMS_TWILIO_AUTH_TOKEN=your_auth_token

# ===== Storage =====
# Adapter: localstorage | s3 | azure
VITE_STORAGE_ADAPTER=localstorage

# For S3 (when adapter=s3)
# VITE_STORAGE_S3_BUCKET=your-bucket-name
# VITE_STORAGE_S3_REGION=us-east-1
# VITE_STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# VITE_STORAGE_S3_ACCESS_KEY_ID=your_access_key
# VITE_STORAGE_S3_SECRET_ACCESS_KEY=your_secret_key

# For Azure Blob (when adapter=azure)
# VITE_STORAGE_AZURE_ACCOUNT_NAME=your_account_name
# VITE_STORAGE_AZURE_ACCOUNT_KEY=your_account_key
# VITE_STORAGE_AZURE_CONTAINER=your_container

# ===== Feature Flags =====
VITE_FEATURE_REPORTS=true
VITE_FEATURE_EMAIL=false
VITE_FEATURE_SMS=false
VITE_FEATURE_SSO=false
VITE_FEATURE_STORAGE=true

# ===== Application =====
VITE_APP_NAME=Persona POS
VITE_APP_ENV=development
