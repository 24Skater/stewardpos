# =============================================================================
# Persona POS Backend Configuration
# =============================================================================
# Copy this file to .env and update with your values
# DO NOT commit .env to version control

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a secure random string (minimum 32 characters)
# You can use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Choose adapter: 'postgres' or 'sqlite'
DB_ADAPTER=sqlite

# PostgreSQL Configuration (if DB_ADAPTER=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=persona_pos
DB_USER=postgres
DB_PASSWORD=postgres

# SQLite Configuration (if DB_ADAPTER=sqlite)
# Path to SQLite database file (will be created if it doesn't exist)
DB_FILENAME=./data/persona-pos.db

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# bcrypt salt rounds (10-12 recommended for production)
BCRYPT_ROUNDS=10
